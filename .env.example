# ─────────────────────────────────────────────────────────────
# NairaFlow – Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Base URL of your FastAPI (or any) backend
# Development:
REACT_APP_API_URL=http://localhost:8000/api/v1

# Production (example):
# REACT_APP_API_URL=https://api.nairaflow.com/api/v1

# ── Optional: Paystack public key (for future payment integration) ──
# REACT_APP_PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxx

# ── Optional: Flutterwave public key ──
# REACT_APP_FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxx
